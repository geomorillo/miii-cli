{
  "name": "miii-agent",
  "version": "0.1.5",
  "description": "Terminal AI coding agent powered by Ollama",
  "type": "module",
  "bin": {
    "miii": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "dev": "tsx watch src/cli.tsx",
    "build": "tsup",
    "postbuild": "node -e \"if(process.platform!=='win32')require('fs').chmodSync('dist/cli.js',0o755)\"",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maruakshay/miii-cli.git"
  },
  "keywords": [
    "cli",
    "ai",
    "ollama",
    "agent",
    "ink",
    "tui"
  ],
  "license": "MIT",
  "dependencies": {
    "execa": "^9.0.0",
    "ink": "^5.0.0",
    "ollama": "^0.5.0",
    "react": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
